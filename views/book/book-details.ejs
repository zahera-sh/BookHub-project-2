<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BookHub | <%= book.title %></title>
    <link rel="icon" href="/images/main/BookHub-logo-mini.png" type="image/png">
    <link rel="stylesheet" href="/css/style-for-all.css">
</head>

<body>

    <%- include("../partials/navbar") %>

        <h1><%= book.title %></h1>

        <img src="/images/books/<%=book.coverPhoto%>" alt="coverPhoto" style="width: 90px; height: 120px; object-fit: cover;">
        
        <p>Authors:</p>
            <% for (let author of book.authors) { %>
                <ul><li><%= author.authorName %></li></ul>
            <% } %>

        <p>Published: <%= book.publishedDate? book.publishedDate.toLocaleDateString("en-GB")
        : "Unknown" %></p>
        
        <p>Description: <%= book.description %></p>
        
        <p>Genres:</p>
            <% for (let genre of book.genres) { %>
                <ul><li><%= genre.genre %></li></ul>
            <% } %>
        
        <p>Page Count: <%= book.pageCount %></p>
        
        <p>Likes: <%= book.likes.length %></p>


        <% if(user && book.likes.some((oneId) => oneId.equals(user._id))) { %>
            <form action="/valley/<%= book._id %>/dislike" method="post">
            <button>🩷</button>
            </form>
        <% } else { %>
            <form action="/valley/<%= book._id %>/like" method="post">
            <button>🩶</button>
            </form>
        <% } %>

        <form action="/mylibrary/<%= book._id %>" method="post">
        <button type="submit">➕</button>
        </form>

</body>

</html>