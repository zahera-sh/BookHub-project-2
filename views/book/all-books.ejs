<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BookHub | The Valley</title>
    <link rel="icon" href="/images/main/BookHub-logo-mini.png" type="image/png">
    <link rel="stylesheet" href="/css/style-for-all.css">
</head>

<body>

    <%- include("../partials/navbar") %>

        <h1>The Book Valley</h1>

        <% for(let oneBook of books){ %>
            <img src="/images/books/<%=oneBook.coverPhoto%>" alt="coverPhoto"  style="width: 90px; height: 120px; object-fit: cover;">
            <a href="/valley/<%=oneBook._id%>"><%= oneBook.title %></a>
            <hr>
        <% } %>

</body>

</html>