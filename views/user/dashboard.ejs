<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BookHub | Dashboard</title>
    <link rel="icon" href="/images/main/BookHub-logo-mini.png" type="image/png">
    <link rel="stylesheet" href="/css/style-for-all.css">
</head>

<body>

    <%- include("../partials/navbar") %>

        <h1>Dashboard</h1>

        <p>Welcome <%= user.username %></p>

        <img src="<%=user.profilePhoto%>" alt="profile-photo" style="width: 100px; height: 100px;">

            <a href="/mylibrary">My Library</a>
                <p>Books in Library: <%= libraryCount.length %></p>

            <p>Following: <%= following.length %></p>
            <% for(let onefollow of following){ %>
                <ul class="followedAuthorsList">
                    <li><a href="/authors/<%=onefollow._id%>"><%=onefollow.authorName%></a></li>
                </ul>
            <% } %>
            
            <p>Liked Books: <%= liked.length %></p>
            <% for(let onelike of liked){ %>
                <ul class="likedBooksList">
                    <li><a href="/valley/<%=onelike._id%>"><%=onelike.title%></a></li>
                </ul>
            <% } %>

            <p>Reviews: <%= reviewCount.length %></p>

            <p>Contributions</p>
                <p>Books Added: <%= booksAdded.length %></p>
                <p>Authors Added: <%= authorsAdded.length %></p>
                    <p>Total: <%= booksAdded.length + authorsAdded.length %></p>
<hr>
        <p>Danger Zone:</p>

            <form action="/dashboard/change-password" method="POST">
                <label for="currentPassword">Current Password</label>
                <input type="password" name="currentPassword" id="currentPassword" required>

                <label for="password">New Password</label>
                <input type="password" name="password" id="password" minlength="8" required />

                <label for="confirmPassword">Confirm Password</label>
                <input type="password" name="confirmPassword" id="confirmPassword" required />

                <button type="submit">Confirm</button>
            </form>

        <form action="/dashboard/<%=user._id%>/confirm-delete" method="GET">
            <button>Delete Account</button>
        </form>

</body>

</html>