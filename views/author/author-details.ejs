<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BookHub | <%= author.authorName %>
    </title>
    <link rel="icon" href="/images/main/BookHub-logo-mini.png" type="image/png">
    <link rel="stylesheet" href="/css/style-for-all.css">
    <link rel="stylesheet" href="/css/author-details.css">
</head>

<body>

    <%- include("../partials/navbar") %>

        <div class="page-container">

            <h1>
                <%= author.authorName %>
            </h1>


            <div class="author-layout">

                <aside class="author-card">

                    <img class="profile-photo" src="/images/authors/<%=author.profilePhoto%>" alt="profilePhoto">


                    <h3>Full Name</h3>

                    <p>
                        <%= author.fullName || "Unknown" %>
                    </p>


                    <h3>Birth Date</h3>

                    <p>
                        <%= author.birthDate ? author.birthDate.toLocaleDateString("en-GB") : "Unknown" %>
                    </p>


                    <h3>Death Date</h3>

                    <p>
                        <%= author.deathDate ? author.deathDate.toLocaleDateString("en-GB") : "Still Alive" %>
                    </p>


                    <h3>Nationality</h3>

                    <p>
                        <%= author.nationality || "Unknown" %>
                    </p>


                    <h3>Followers</h3>

                    <p>
                        <%= author.followers.length %>
                    </p>

                </aside>




                <section class="actions-card">

                    <h2>Reader Actions</h2>


                    <% if(user && author.followers.some((oneId)=> oneId.equals(user._id))) { %>

                        <form action="/authors/<%= author._id %>/unfollow" method="POST">

                            <button type="submit">
                                Unfollow Author
                            </button>

                        </form>

                        <% } else { %>

                            <form action="/authors/<%= author._id %>/follow" method="POST">

                                <button type="submit">
                                    Follow Author
                                </button>

                            </form>

                            <% } %>

                </section>

            </div>



            <div class="books-card">

                <h2>Books by this Author</h2>

                <% for (let book of booksByAuthor) { %>

                    <a class="book-link" href="/valley/<%= book._id %>">

                        <%= book.title %>

                    </a>

                    <% } %>

            </div>




            <% if(user && user.isAdmin){ %>

                <div class="danger-zone">

                    <h2>Admin Controls</h2>

                    <form action="/authors/<%= author._id %>?_method=DELETE" method="POST"
                        onsubmit="return confirm('Are you sure you want to delete this author?')">

                        <button class="delete-btn">
                            Delete Author
                        </button>

                    </form>

                </div>

                <% } %>


        </div>

</body>

</html>