<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BookHub | Add Author</title>
    <link rel="icon" href="/images/main/BookHub-logo-mini.png" type="image/png">
    <link rel="stylesheet" href="/css/style-for-all.css">
    <link rel="stylesheet" href="/css/add-new-ab.css">
</head>

<body>

    <%- include("../partials/navbar") %>

        <h1>Contribute by adding a new Author</h1>

        <form action="/authors" method="POST" enctype="multipart/form-data">

            <div class="form-group">
                <label for="authorName">Author Name:</label>
                <input type="text" name="authorName" id="authorName" minlength="3" required>
            </div>

            <div class="form-group">
                <label for="fullName">Full Name:</label>
                <input type="text" name="fullName" id="fullName">
            </div>

            <div class="form-group">
                <label for="profilePhoto">Add Photo:</label>
                <input type="file" name="profilePhoto" id="profilePhoto">
            </div>

            <div class="form-group">
                <label for="birthDate">Birth Date:</label>
                <input type="date" name="birthDate" id="birthDate">
            </div>

            <div class="form-group">
                <label for="deathDate">Death Date:</label>
                <input type="date" name="deathDate" id="deathDate">
            </div>

            <div class="form-group">
                <label for="nationality">Nationality:</label>
                <input type="text" name="nationality" id="nationality">
            </div>

            <button type="submit">Add</button>

        </form>

</body>

</html>